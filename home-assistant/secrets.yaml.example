# Copy to secrets.yaml and fill in.  secrets.yaml is .gitignored.

mqtt_broker: localhost
mqtt_port: 1883
mqtt_user: ha
mqtt_pass: REPLACE_ME

# Pushover (Phase 6 — direct-from-boat path is on the ESP32; HA uses
# Companion notifications by default, but this is here for the optional
# HA-side Pushover service).
pushover_user_key: REPLACE_ME
pushover_api_token: REPLACE_ME

# Optional: Twilio (only if user has their own subscription)
twilio_account_sid: REPLACE_ME
twilio_auth_token: REPLACE_ME
twilio_from_number: REPLACE_ME
