# EvenKeel — local dev secrets (template).
#
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit it.

# Wokwi simulator API token. Get from https://wokwi.com/dashboard/ci
# (free for public repos). Used by tests/wokwi/ + the wokwi-ci-action
# in .github/workflows/. Drop the raw token (no quotes, no prefix) on
# the WOKWI_CLI_TOKEN= line.
WOKWI_CLI_TOKEN=

# Optional: HA long-lived access token for live-mode tests.
HA_TOKEN=

# Optional: Pushover (Phase 6 critical-alert path on the boat firmware).
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=
